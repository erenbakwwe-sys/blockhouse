rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // For this prototype, we'll allow all operations so the app works without Firebase Auth configuration.
      // In a real app, you would check a custom claim or an admin collection.
      return true;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidMenuItem(data) {
      return data.keys().hasAll(['id', 'name', 'description', 'price', 'category', 'image']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() < 1000 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.image is string && data.image.size() < 1000;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'table', 'items', 'status', 'total', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.table is string && data.table.size() > 0 && data.table.size() < 50 &&
             data.items is list && data.items.size() <= 100 &&
             data.status in ['received', 'pending', 'preparing', 'ready', 'served', 'paid'] &&
             data.total is number && data.total >= 0 &&
             data.createdAt is number;
    }

    function isValidWaiterCall(data) {
      return data.keys().hasAll(['id', 'table', 'status', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.table is string && data.table.size() > 0 && data.table.size() < 50 &&
             data.status in ['active', 'resolved'] &&
             data.createdAt is number;
    }

    function isValidTable(data) {
      return data.keys().hasAll(['id', 'number']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.number is string && data.number.size() > 0 && data.number.size() < 50;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['id', 'description', 'amount', 'category', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             data.amount is number && data.amount > 0 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.createdAt is number;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['estimatedPrepTime']) &&
             data.estimatedPrepTime is number && data.estimatedPrepTime >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Menu: Anyone can read, only admins can write
    match /menu/{itemId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidMenuItem(request.resource.data);
      allow delete: if isAdmin();
    }

    // Orders: Anyone can create (customers), admins can read/update/delete
    match /orders/{orderId} {
      allow create: if isValidOrder(request.resource.data);
      allow read: if true;
      allow update, delete: if isAdmin();
    }

    // Waiter Calls: Anyone can create (customers), admins can read/update/delete
    match /calls/{callId} {
      allow create: if isValidWaiterCall(request.resource.data);
      allow read: if true;
      allow update, delete: if isAdmin();
    }

    // Tables: Anyone can read, admins can write
    match /tables/{tableId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidTable(request.resource.data);
      allow delete: if isAdmin();
    }

    // Expenses: Admins only
    match /expenses/{expenseId} {
      allow read, delete: if isAdmin();
      allow create, update: if isAdmin() && isValidExpense(request.resource.data);
    }

    // Settings: Anyone can read, admins can write
    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSettings(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
